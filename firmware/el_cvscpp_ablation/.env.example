# Local STM32N6 flash/run settings for firmware/el_cvscpp_ablation.
#
# Copy this file to firmware/el_cvscpp_ablation/.env and adjust the local paths.
# The .env file is intentionally ignored by git. Keep the legacy C checkout
# outside this repository; the firmware Makefile links it from EL_CVSCPP_EDGE_C_ROOT.

EL_CVSCPP_PROJECT_ROOT=/absolute/path/to/STM32CubeIDE/workspace_2.0.0/EL_C_vsCpp
EL_CVSCPP_EDGE_C_ROOT=/absolute/path/to/legacy/EdgeLearning
EL_CVSCPP_RLTOOLS_ROOT=/absolute/path/to/rl-tools

EL_CVSCPP_TOOLCHAIN_BIN=/Applications/STM32CubeIDE.app/Contents/Eclipse/plugins/com.st.stm32cube.ide.mcu.externaltools.gnu-tools-for-stm32.13.3.rel1.macos64_1.0.100.202509120712/tools/bin
EL_CVSCPP_STLINK_GDBSERVER=/Applications/STM32CubeIDE.app/Contents/Eclipse/plugins/com.st.stm32cube.ide.mcu.externaltools.stlink-gdb-server.macos64_2.2.300.202509021040/tools/bin/ST-LINK_gdbserver
EL_CVSCPP_CUBEPROG_BIN=/Applications/STM32CubeIDE.app/Contents/Eclipse/plugins/com.st.stm32cube.ide.mcu.externaltools.cubeprogrammer.macos64_2.2.300.202508131133/tools/bin
EL_CVSCPP_EXTERNAL_LOADER=/Applications/STM32CubeIDE.app/Contents/Eclipse/plugins/com.st.stm32cube.ide.mcu.externaltools.cubeprogrammer.macos64_2.2.300.202508131133/tools/bin/ExternalLoader/MX25UM51245G_STM32N6570-NUCLEO.stldr

EL_CVSCPP_PYTHON=/absolute/path/to/python-with-pyserial
EL_CVSCPP_SERIAL_PORT=/dev/tty.usbmodem1102
EL_CVSCPP_SERIAL_BAUDRATE=12000000
EL_CVSCPP_SERIAL_TIMEOUT=120
EL_CVSCPP_GDB_PORT=61234
EL_CVSCPP_JOBS=7

EL_CVSCPP_APPLI_PROJECT_NAME=EL_C_vsCpp_Appli
EL_CVSCPP_FSBL_PROJECT_NAME=EL_C_vsCpp_FSBL
EL_CVSCPP_BUILD_CONFIG=EL_C_vsCpp_Ablation_DEBUG
EL_CVSCPP_INPUT_FEATURES=3
