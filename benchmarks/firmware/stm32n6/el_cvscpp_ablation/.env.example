# Local STM32N6 flash/run settings for benchmarks/firmware/stm32n6/el_cvscpp_ablation.
#
# Copy this file to benchmarks/firmware/stm32n6/el_cvscpp_ablation/.env and adjust the local paths.
# The .env file is intentionally ignored by git. The public C++/RLTools
# firmware benchmark does not need the legacy C checkout. Set
# EL_CVSCPP_EDGE_C_ROOT only for the private legacy-C ablation variants.

EL_CVSCPP_PROJECT_ROOT=/absolute/path/to/EL_C_vsCpp
EL_CVSCPP_RLTOOLS_ROOT=/absolute/path/to/rl-tools

# Optional/private. Required only for variants:
# all, legacy_c, cpp_direct_c_backend.
# EL_CVSCPP_EDGE_C_ROOT=/absolute/path/to/legacy/EdgeLearning

# Point these at the STM32CubeIDE/CubeProgrammer installation on this machine.
# Keep the exact plugin version and OS suffix local to .env.
EL_CVSCPP_TOOLCHAIN_BIN=/absolute/path/to/arm-none-eabi-tools/bin
EL_CVSCPP_STLINK_GDBSERVER=/absolute/path/to/ST-LINK_gdbserver
EL_CVSCPP_CUBEPROG_BIN=/absolute/path/to/STM32CubeProgrammer/bin

# Optional. If left empty, flash_and_run_n6.sh uses:
# $EL_CVSCPP_CUBEPROG_BIN/ExternalLoader/MX25UM51245G_STM32N6570-NUCLEO.stldr
EL_CVSCPP_EXTERNAL_LOADER=

EL_CVSCPP_PYTHON=/absolute/path/to/python-with-pyserial
EL_CVSCPP_SERIAL_PORT=/dev/tty.usbmodemXXXX
EL_CVSCPP_SERIAL_BAUDRATE=12000000
EL_CVSCPP_SERIAL_TIMEOUT=120
EL_CVSCPP_GDB_PORT=61234
EL_CVSCPP_JOBS=7

EL_CVSCPP_APPLI_PROJECT_NAME=EL_C_vsCpp_Appli
EL_CVSCPP_FSBL_PROJECT_NAME=EL_C_vsCpp_FSBL
EL_CVSCPP_BUILD_CONFIG=EL_C_vsCpp_Ablation_DEBUG
EL_CVSCPP_INPUT_FEATURES=3
